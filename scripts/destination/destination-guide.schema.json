{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cordalsur.example/schemas/destination-guide.schema.json",
  "title": "CordalSur destination guide",
  "type": "object",
  "required": ["schemaVersion", "meta", "geometry", "categories", "places", "offerings", "routes", "providers"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "meta": {
      "type": "object",
      "required": ["generatedAt", "coverage", "statistics", "limitations"],
      "properties": {
        "generatedAt": { "type": "string", "format": "date-time" },
        "coverage": { "type": "string" },
        "statistics": { "type": "object" },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "geometry": { "type": "object" },
    "categories": { "type": "array", "minItems": 1 },
    "places": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "location", "coordinateKind", "navigationUrl", "googleMapsUrl", "sources", "distanceFromApartment"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "category": { "type": "string" },
          "location": {
            "type": "object",
            "required": ["lat", "lon"],
            "properties": { "lat": { "type": "number" }, "lon": { "type": "number" } }
          },
          "coordinateKind": { "enum": ["entrance", "parking", "node", "manual_verified", "manual_catalog", "google_maps_place", "center_candidate"] },
          "coordinatePrecision": { "type": "string" },
          "routingEligible": { "type": "boolean" },
          "navigationUrl": { "type": "string", "format": "uri" },
          "googleMapsUrl": { "type": "string", "format": "uri" },
          "distanceFromApartment": {
            "type": "object",
            "required": ["meters", "source", "target", "confidence", "roadDestinationId", "accessNearby", "coverage"],
            "properties": {
              "meters": { "type": "number", "minimum": 0 },
              "source": { "enum": ["road-apartment", "direct-apartment", "sector-apartment", "road-trailhead-apartment", "direct-trailhead-apartment"] },
              "target": { "enum": ["place", "locality", "trailhead"] },
              "confidence": { "enum": ["verified", "mapped", "approximate"] },
              "label": { "type": ["string", "object", "null"] },
              "roadDestinationId": { "type": "string", "minLength": 1 },
              "accessNearby": { "type": "boolean" },
              "coverage": { "enum": ["covered", "direct"] }
            }
          },
          "catalogAccess": {
            "type": "object",
            "required": ["type", "label", "location", "confidence", "navigationUrl", "googleMapsUrl", "source"],
            "properties": {
              "type": { "const": "trailhead" },
              "label": { "type": "object" },
              "location": {
                "type": "object",
                "required": ["lat", "lon"],
                "properties": { "lat": { "type": "number" }, "lon": { "type": "number" } }
              },
              "confidence": { "enum": ["verified", "mapped", "approximate"] },
              "navigationUrl": { "type": "string", "format": "uri" },
              "googleMapsUrl": { "type": "string", "format": "uri" },
              "source": { "type": "object" }
            }
          },
          "sources": { "type": "array", "minItems": 1 }
        }
      }
    },
    "offerings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "module", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "name": { "type": "object" },
          "module": { "type": "string", "minLength": 1 },
          "officialUrl": { "type": ["string", "null"] },
          "verifiedAt": { "type": ["string", "null"] },
          "status": { "type": "string", "minLength": 1 }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "activityType", "navigationAvailable", "status", "warning"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "object" },
          "activityType": { "type": "string", "minLength": 1 },
          "navigationAvailable": { "const": false },
          "navigationUrl": { "type": "null" },
          "status": { "type": "string", "minLength": 1 },
          "warning": { "type": "object" }
        }
      }
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "enabled"],
        "properties": {
          "id": { "enum": ["manual", "editorial", "osm", "google", "tripadvisor"] },
          "enabled": { "type": "boolean" },
          "records": { "type": "integer", "minimum": 0 },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
